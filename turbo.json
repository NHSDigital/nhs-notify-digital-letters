{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "generate-dependencies": {
      "dependsOn": [
        "^generate-dependencies"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "lint:fix": {
      "dependsOn": [
        "^lint:fix"
      ]
    },
    "test:contract": {
      "dependsOn": [
        "^test:contract"
      ]
    },
    "test:unit": {
      "dependsOn": [
        "^test:unit"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    }
  }
}
