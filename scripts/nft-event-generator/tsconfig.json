{
  "compilerOptions": {
    "baseUrl": "./src/",
    "isolatedModules": true,
    "paths": {
      "jest": [
        "../../../node_modules/jest"
      ]
    },
    "typeRoots": [
      "../../node_modules/@types",
      "./node_modules/@types"
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": [
    "src/**/*",
    "./jest.config.ts",
    "./jest.setup.ts"
  ]
}
